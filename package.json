{
  "name": "Hack_It_App_Backend",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server.js",
  "scripts": {
    "dev": "pnpm exec nodemon",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "docker:dev": "docker compose -f docker-compose.dev.yml up -d --build",
    "docker:prod": "docker compose -f docker-compose.prod.yml up -d --build",
    "docker:dev:restart": "docker compose -f docker-compose.dev.yml restart",
    "docker:prod:restart": "docker compose -f docker-compose.prod.yml restart",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "docker:dev:logs": "docker logs -f hackit_app_dev",
    "docker:prod:logs": "docker logs -f hackit_app_prod"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.17.1",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "chalk": "^5.6.2",
    "cloudinary": "^2.8.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-async-handler": "^1.2.0",
    "firebase-admin": "^13.6.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.1.1",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^7.0.12",
    "zod": "^4.3.2",
    "zod-form-data": "^3.0.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/chalk": "^2.2.4",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.3",
    "@types/nodemailer": "^7.0.4",
    "nodemon": "^3.1.11",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
